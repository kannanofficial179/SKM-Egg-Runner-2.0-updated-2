{
  "name": "skm-egg-runner-functions",
  "version": "1.0.0",
  "private": true,
  "engines": { "node": "20" },
  "main": "lib/index.js",
  "scripts": {
    "build":  "tsc",
    "watch":  "tsc --watch",
    "deploy": "npm run build && firebase deploy --only functions --project skm-egg-runner",
    "serve":  "npm run build && firebase emulators:start --only functions"
  },
  "dependencies": {
    "firebase-admin":    "^12.0.0",
    "firebase-functions": "^5.0.0"
  },
  "devDependencies": {
    "typescript":        "~5.4.0",
    "@types/node":       "^20.0.0"
  }
}
