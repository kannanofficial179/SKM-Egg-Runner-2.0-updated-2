rules_version = '2';

// ──────────────────────────────────────────────────────────────
// SKM EGG RUNNER + PROTEIN TRACKER 2.0 — Firestore Security Rules
// ──────────────────────────────────────────────────────────────

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Core auth helpers ────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    function onlyFields(allowed) {
      return request.resource.data.keys().hasOnly(allowed);
    }

    // ── Developer role check ─────────────────────────────────
    // Reads the authenticated user's own document and checks role == "developer".
    // This is safe: it only reads the caller's own doc, and only if authenticated.
    function isDeveloper() {
      return isAuth()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'developer';
    }

    // ── GAME COLLECTIONS ────────────────────────────────────

    match /users/{uid} {
      // Owner reads their own doc; developers read any user doc for analytics
      allow read:   if isOwner(uid) || isDeveloper();
      allow create: if isOwner(uid)
                    && request.resource.data.uid == uid
                    && request.resource.data.playerName is string
                    && request.resource.data.playerName.size() >= 2
                    && request.resource.data.playerName.size() <= 30;
      // Owner updates own fields; developer may set role field on any user
      allow update: if isOwner(uid)
                    || (isDeveloper() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['role','updatedAt']));
      allow delete: if false;
    }

    match /leaderboard/{uid} {
      allow read:   if isAuth();
      allow create: if isOwner(uid)
                    && request.resource.data.uid == uid
                    && request.resource.data.score is int
                    && request.resource.data.score >= 0
                    && request.resource.data.distance >= 0
                    && request.resource.data.playerName is string
                    && request.resource.data.playerName.size() >= 2;
      allow update: if isOwner(uid)
                    && request.resource.data.score >= resource.data.score;
      allow delete: if false;
    }

    match /missions/{uid}/daily/{missionId} {
      allow read:   if isOwner(uid) || isDeveloper();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid)
                    && request.resource.data.progress <= resource.data.target
                    && request.resource.data.progress >= 0
                    && (resource.data.claimed == false || request.resource.data.claimed == true);
      allow delete: if false;
    }

    match /achievements/{uid}/list/{achievementId} {
      allow read:   if isOwner(uid) || isDeveloper();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid)
                    && request.resource.data.progress >= 0
                    && (resource.data.claimed == false || request.resource.data.claimed == true);
      allow delete: if false;
    }

    match /settings/{uid} {
      allow read:  if isOwner(uid) || isDeveloper();
      allow write: if isOwner(uid)
                   && onlyFields(['uid','musicEnabled','sfxEnabled','vibrationEnabled','reminderEnabled','reminderTimes','updatedAt']);
    }

    match /qrCodes/{code} {
      allow read:   if isAuth();
      // Any authenticated user can scan a QR code.
      // Rule: new playCount must be exactly old + 1, must not exceed maxPlays,
      // and other fields (dailyScans, lastScannedAt) may also be written.
      // NOTE: we do NOT use FieldValue.increment() in the scan transaction
      // because Security Rules evaluate request.resource.data which contains
      // the final merged value — plain integer assignment is fully verifiable.
      allow update: if isAuth()
                    && request.resource.data.playCount == resource.data.playCount + 1
                    && request.resource.data.playCount <= resource.data.maxPlays
                    && request.resource.data.active    == resource.data.active
                    && request.resource.data.maxPlays  == resource.data.maxPlays;
      // Developer: full update access (bulk disable / enable / admin ops)
      allow update: if isDeveloper();
      allow create: if isAuth();
      // Only developers can delete QR codes
      allow delete: if isDeveloper();
    }

    // Protein scan dedup — one doc per user+QR combination.
    // Doc ID is "{uid}_{qrCode}". Any authenticated user can read/create
    // their own dedup records. resource.data is null on missing docs so
    // we cannot check resource.data.userId on read — allow any auth read.
    match /proteinScans/{scanId} {
      allow read:   if isAuth();
      allow create: if isAuth()
                    && request.auth.uid == request.resource.data.userId
                    && request.resource.data.proteinAdded is number
                    && request.resource.data.qrId is string;
      allow update: if false;
      allow delete: if false;
    }

    // Admin operation log — developer read/write only
    match /qrOperationLogs/{logId} {
      allow read:   if isDeveloper();
      allow create: if isDeveloper();
      allow update: if false;
      allow delete: if false;
    }

    match /gameConfig/{docId} {
      allow read:  if isAuth();
      // Developer may write config; fallback UID kept for backward compat
      allow write: if isDeveloper()
                   || (isAuth() && request.auth.uid == 'YOUR_DEVELOPER_UID');
    }

    // Game missions (subcollection used by game engine)
    match /game_missions/{uid}/{document=**} {
      allow read:   if isOwner(uid) || isDeveloper();
      allow write:  if isOwner(uid);
    }

    // ── PROTEIN TRACKER COLLECTIONS ─────────────────────────

    match /protein_logs/{uid}/entries/{entryId} {
      allow read:   if isOwner(uid) || isDeveloper();
      allow create: if isOwner(uid)
                    && request.resource.data.uid == uid
                    && request.resource.data.protein is number
                    && request.resource.data.protein >= 0;
      allow update: if isOwner(uid);
      allow delete: if isOwner(uid);
    }

    match /daily_stats/{uid}/days/{dateKey} {
      allow read:   if isOwner(uid) || isDeveloper();
      allow create: if isOwner(uid) && request.resource.data.uid == uid;
      allow update: if isOwner(uid);
      allow delete: if false;
    }

    match /tracker_achievements/{uid}/list/{achievementId} {
      allow read:   if isOwner(uid) || isDeveloper();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid);
      allow delete: if false;
    }

    match /tracker_challenges/{uid}/list/{challengeId} {
      allow read:   if isOwner(uid) || isDeveloper();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid);
      allow delete: if false;
    }

    match /userSummary/{uid} {
      allow read:  if isOwner(uid) || isDeveloper();
      allow write: if isOwner(uid);
    }

    match /tracker_settings/{uid} {
      allow read:  if isOwner(uid) || isDeveloper();
      allow write: if isOwner(uid);
    }

    match /tracker_rewards/{uid} {
      allow read:  if isOwner(uid) || isDeveloper();
      allow write: if isOwner(uid);
    }

    match /tracker_leaderboard/{uid} {
      allow read:   if isAuth();
      allow create: if isOwner(uid) && request.resource.data.uid == uid;
      allow update: if isOwner(uid);
      allow delete: if false;
    }

    // ── RETENTION COLLECTIONS ─────────────────────────────────

    match /login_streaks/{uid} {
      allow read:  if isOwner(uid) || isDeveloper();
      allow write: if isOwner(uid);
    }
    match /login_streaks/{uid}/claims/{claimId} {
      allow read:  if isOwner(uid) || isDeveloper();
      allow create: if isOwner(uid);
      allow update: if false;
      allow delete: if false;
    }

    match /daily_missions/{uid}/days/{missionId} {
      allow read:   if isOwner(uid) || isDeveloper();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid);
      allow delete: if false;
    }

    match /weekly_missions/{uid}/weeks/{missionId} {
      allow read:   if isOwner(uid) || isDeveloper();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid);
      allow delete: if false;
    }

    match /streak_shields/{uid} {
      allow read:  if isOwner(uid) || isDeveloper();
      allow write: if isOwner(uid);
    }

    match /game_rewards/{uid}/unlocked/{rewardId} {
      allow read:   if isOwner(uid) || isDeveloper();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid);
      allow delete: if false;
    }

  }
}
